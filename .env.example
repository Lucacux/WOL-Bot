DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id
WOL_INTERFACE=eth0

# ── Servidores ────────────────────────────────────────────────
# Cada servidor: nombre, MAC (para WOL), IP (para ping/SSH) y emoji del panel.
NAME_NAS=NAS
MAC_NAS=00:00:00:00:00:00
IP_NAS=192.168.1.10
EMOJI_NAS=🗄️

NAME_MEDIA=Media Server
MAC_MEDIA=00:00:00:00:00:00
IP_MEDIA=192.168.1.20
EMOJI_MEDIA=📺

# ── SSH por servidor (apagado / reinicio remoto) ──────────────
# Media es la credencial base; NAS hereda user/key de Media si no lo pisás.
SSH_USER_MEDIA=youruser
SSH_KEY_MEDIA=/home/youruser/.ssh/id_ed25519_wol
SSH_PORT_MEDIA=22

# Opcionales: solo si el NAS usa otro usuario/clave/puerto que el Media.
SSH_USER_NAS=youruser
SSH_KEY_NAS=/home/youruser/.ssh/id_ed25519_wol
SSH_PORT_NAS=22

# ── Failsafe watchdog (auto re-wake dentro de la franja del /schedule) ──
# Aplica por servidor (cada uno con su horario/franja). Todos opcionales;
# estos son los valores por defecto.
FAILSAFE_CHECK_SECS=60       # cadencia del watchdog (1 ping ICMP por ciclo si está ON)
FAILSAFE_CONFIRM_CHECKS=3    # pings fallidos consecutivos para declarar caída (debounce)
FAILSAFE_CONFIRM_GAP=5       # segundos entre pings de confirmación
FAILSAFE_WOL_COOLDOWN=180    # espera tras un WOL antes de reintentar (deja bootear)
FAILSAFE_MAX_FAST_TRIES=3    # intentos rápidos antes de pasar a modo lento
FAILSAFE_SLOW_COOLDOWN=600   # cooldown en modo lento (ej. apagón prolongado)
FAILSAFE_BOOT_GRACE=150      # gracia al entrar en franja / reiniciar el bot
